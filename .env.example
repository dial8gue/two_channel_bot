# Telegram
BOT_TOKEN=your_bot_token_here
ADMIN_ID=123456789
DEBUG_MODE=false

# Timezone (optional)
# Use IANA timezone identifiers for timestamp display
# Examples: Europe/Moscow, America/New_York, Asia/Tokyo, Europe/London
# If not set or invalid, defaults to UTC
# TIMEZONE=Europe/Moscow

# OpenAI
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# Model for question classification (lightweight, fast)
CLASSIFIER_MODEL=google/gemini-2.5-flash-lite
MAX_TOKENS=4000

# Database
DB_PATH=/app/data/bot.db
STORAGE_PERIOD_HOURS=168

# Analysis
ANALYSIS_PERIOD_HOURS=24

# User Analysis Command
# Analysis period for /anal command (hours), default 8
ANAL_PERIOD_HOURS=8

# Cache
CACHE_TTL_MINUTES=60

# Debounce
DEBOUNCE_INTERVAL_SECONDS=21600

# Inline Mode (answering questions in chats)
# Debounce interval for regular users (seconds), default 3600 (1 hour)
INLINE_DEBOUNCE_SECONDS=3600
# Maximum tokens for inline answers
INLINE_MAX_TOKENS=500

# Collection
COLLECTION_ENABLED=true

# Vision (image recognition)
# Model for image recognition via OpenAI-compatible API
VISION_MODEL=google/gemini-2.5-flash
# Enable/disable image recognition (true/false)
VISION_ENABLED=true
# Maximum tokens for vision model response
VISION_MAX_TOKENS=2000

# Guest Mode (Bot API 10.0, aiogram 3.28+)
# Allows the bot to reply in chats where it is NOT a member when mentioned
# or replied to. Requires 'Guest Mode' enabled in @BotFather MiniApp.
# One reply per guest query, no chat history access.
GUEST_MODE_ENABLED=false
# Per-user debounce interval for guest answers (seconds)
GUEST_DEBOUNCE_SECONDS=60

# Web Search (OpenRouter "server tool")
# Requires OPENAI_BASE_URL=https://openrouter.ai/api/v1 — this feature is
# specific to OpenRouter's `openrouter:web_search` tool and does NOT work
# with OpenAI's own endpoint or other proxies.
# Master on/off switch. When off, no tools are added to requests.
WEB_SEARCH_ENABLED=false
# Search engine: auto (default), native, exa, firecrawl, parallel.
# We pick `exa` for consistent behaviour across any underlying LLM.
WEB_SEARCH_ENGINE=exa
# Max results per single search call (1..25). Keep small to save tokens.
WEB_SEARCH_MAX_RESULTS=3
# Max total results across all search calls in a single request.
# Caps agentic loops where the model might call search several times.
WEB_SEARCH_MAX_TOTAL_RESULTS=3
# Context size per result (only honored by Exa/Parallel): low | medium | high.
# `low` = shortest snippet, lowest prompt cost.
WEB_SEARCH_CONTEXT_SIZE=low

# Buffering (optional)
BUFFER_SIZE=50
BUFFER_FLUSH_INTERVAL_SECONDS=30
# Message Formatting
DEFAULT_PARSE_MODE=Markdown
ENABLE_MARKDOWN_ESCAPING=true
MAX_MESSAGE_LENGTH=4096
